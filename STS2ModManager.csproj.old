<Project Sdk="Godot.NET.Sdk/4.5.1">
  <PropertyGroup>
    <TargetFramework>net8.0-windows</TargetFramework>
    <EnableDynamicLoading>true</EnableDynamicLoading>
    <RootNamespace>STS2ModManager</RootNamespace>
    <AllowUnsafeBlocks>true</AllowUnsafeBlocks>
  </PropertyGroup>
  <ItemGroup>
    <PackageReference Include="Microsoft.Web.WebView2" Version="1.0.2651.64" />
  </ItemGroup>
  <ItemGroup>
    <!-- 排除所有 CEF 相关文件 -->
    <Compile Remove="GDCefGlue-main/**/*" />
    <Compile Remove="addons/GCefGlue.bak/**/*" />
    <!-- 排除 browser_host（独立构建） -->
    <Compile Remove="browser_host/**/*" />
  </ItemGroup>
</Project>