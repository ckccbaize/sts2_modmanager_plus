{
  "manifest_version": 3,
  "name": "STS2 Mod Manager",
  "version": "3.6",
  "description": "Download mods directly to STS2 Mod Manager from Nexus Mods - No Premium required",
  "permissions": [
    "activeTab",
    "storage",
    "tabs",
    "webRequest",
    "downloads",
    "https://www.nexusmods.com/*"
  ],
  "host_permissions": [
    "*://localhost*/*",
    "*://files.nexusmods.com/*",
    "*://cdn.nexusmods.com/*"
  ],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "https://www.nexusmods.com/slaythespire2/mods/*"
      ],
      "js": ["content.js"],
      "run_at": "document_end"
    }
  ],
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}